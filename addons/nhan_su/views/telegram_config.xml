<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_telegram_config_tree" model="ir.ui.view">
        <field name="name">telegram.config.tree</field>
        <field name="model">telegram.config</field>
        <field name="arch" type="xml">
            <tree string="Cấu hình Telegram Bot">
                <field name="ten"/>
                <field name="bot_token" password="True"/>
                <field name="chat_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_telegram_config_form" model="ir.ui.view">
        <field name="name">telegram.config.form</field>
        <field name="model">telegram.config</field>
        <field name="arch" type="xml">
            <form string="Cấu hình Telegram Bot">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="ten" placeholder="Ví dụ: Bot Thông báo Lương"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="bot_token" password="True"/>
                            <field name="chat_id"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>Hướng dẫn:</strong>
                        <ul>
                            <li>Token lấy từ @BotFather trên Telegram.</li>
                            <li>Chat ID có thể lấy qua @userinfobot hoặc các bot tương tự.</li>
                            <li>Hệ thống sẽ dùng cấu hình đang "Kích hoạt" để gửi thông báo.</li>
                        </ul>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_telegram_config" model="ir.actions.act_window">
        <field name="name">Cấu hình Telegram Bot</field>
        <field name="res_model">telegram.config</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
