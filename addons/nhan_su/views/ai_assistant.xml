<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ===================== CẤU HÌNH API ===================== -->
        
        <!-- Form View - Cấu hình API -->
        <record id="view_ai_cau_hinh_api_form" model="ir.ui.view">
            <field name="name">ai.cau_hinh_api.form</field>
            <field name="model">ai.cau_hinh_api</field>
            <field name="arch" type="xml">
                <form string="Cấu hình API AI">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="ten" placeholder="Tên cấu hình"/>
                            </h1>
                        </div>
                        
                        <group>
                            <group string="Thông tin API">
                                <field name="api_url"/>
                                <field name="model_name"/>
                                <field name="active"/>
                            </group>
                            <group string="Xác thực">
                                <field name="api_key" password="True"/>
                            </group>
                        </group>
                        
                        <div class="alert alert-info" role="alert">
                            <strong>Hướng dẫn lấy Gemini API Key:</strong>
                            <ol>
                                <li>Truy cập <a href="https://aistudio.google.com/apikey" target="_blank">aistudio.google.com/apikey</a></li>
                                <li>Đăng nhập bằng tài khoản Google</li>
                                <li>Nhấn <strong>"Create API Key"</strong> → copy key bắt đầu bằng <code>AIzaSy...</code></li>
                                <li>Dán vào ô <strong>API Key</strong> bên trên, để trống <strong>API URL</strong></li>
                                <li>Model mặc định: <code>gemini-1.5-flash</code> (miễn phí, không cần billing)</li>
                            </ol>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Tree View - Cấu hình API -->
        <record id="view_ai_cau_hinh_api_tree" model="ir.ui.view">
            <field name="name">ai.cau_hinh_api.tree</field>
            <field name="model">ai.cau_hinh_api</field>
            <field name="arch" type="xml">
                <tree string="Danh sách cấu hình API">
                    <field name="ten"/>
                    <field name="api_url"/>
                    <field name="model_name"/>
                    <field name="active" widget="boolean_toggle"/>
                </tree>
            </field>
        </record>
        
        <!-- Action - Cấu hình API -->
        <record id="action_ai_cau_hinh_api" model="ir.actions.act_window">
            <field name="name">Cấu hình API AI</field>
            <field name="res_model">ai.cau_hinh_api</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo cấu hình API AI
                </p>
                <p class="text-muted">
                    Nhập API Key từ OpenRouter để sử dụng AI Assistant.
                </p>
            </field>
        </record>
        
        <!-- ===================== LỊCH SỬ CHAT ===================== -->
        
        <!-- Form View - Lịch sử chat -->
        <record id="view_ai_lich_su_chat_form" model="ir.ui.view">
            <field name="name">ai.lich_su_chat.form</field>
            <field name="model">ai.lich_su_chat</field>
            <field name="arch" type="xml">
                <form string="Chi tiết chat" create="false" edit="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="user_id"/>
                                <field name="thoi_gian"/>
                                <field name="thanh_cong"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Câu hỏi &amp; Trả lời">
                                <group string="Câu hỏi">
                                    <field name="cau_hoi" nolabel="1"/>
                                </group>
                                <group string="Trả lời AI">
                                    <field name="tra_loi" nolabel="1"/>
                                </group>
                            </page>
                            <page string="Context Data">
                                <field name="context_data" nolabel="1"/>
                            </page>
                            <page string="Lỗi" attrs="{'invisible': [('thanh_cong', '=', True)]}">
                                <field name="loi" nolabel="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Tree View - Lịch sử chat -->
        <record id="view_ai_lich_su_chat_tree" model="ir.ui.view">
            <field name="name">ai.lich_su_chat.tree</field>
            <field name="model">ai.lich_su_chat</field>
            <field name="arch" type="xml">
                <tree string="Lịch sử chat AI" decoration-success="thanh_cong == True" decoration-danger="thanh_cong == False">
                    <field name="thoi_gian"/>
                    <field name="user_id"/>
                    <field name="cau_hoi"/>
                    <field name="thanh_cong" widget="boolean"/>
                </tree>
            </field>
        </record>
        
        <!-- Action - Lịch sử chat -->
        <record id="action_ai_lich_su_chat" model="ir.actions.act_window">
            <field name="name">Lịch sử chat AI</field>
            <field name="res_model">ai.lich_su_chat</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'create': False, 'edit': False}</field>
        </record>
        
        <!-- ===================== AI ASSISTANT (WIZARD) ===================== -->
        
        <!-- Form View - AI Assistant -->
        <record id="view_ai_assistant_form" model="ir.ui.view">
            <field name="name">ai.assistant.form</field>
            <field name="model">ai.assistant</field>
            <field name="arch" type="xml">
                <form string="AI Assistant - Trợ lý thông minh">
                    <sheet>
                        <!-- HEADER -->
                        <div style="
                            background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
                            border-radius: 16px;
                            padding: 28px 32px;
                            margin-bottom: 20px;
                            text-align: center;
                            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
                        ">
                            <div style="
                                display: inline-flex;
                                align-items: center;
                                justify-content: center;
                                width: 64px; height: 64px;
                                background: rgba(255,255,255,0.15);
                                border-radius: 50%;
                                margin-bottom: 12px;
                                backdrop-filter: blur(10px);
                            ">
                                <i class="fa fa-robot" style="font-size: 32px; color: #64b5f6;"/>
                            </div>
                            <h2 style="color: #ffffff; margin: 0 0 6px 0; font-size: 22px; font-weight: 700; letter-spacing: 0.5px;">
                                AI HR Assistant
                            </h2>
                            <p style="color: rgba(255,255,255,0.65); margin: 0; font-size: 13px;">
                                Trợ lý thông minh — hỏi về nhân viên, chấm công, lương...
                            </p>
                        </div>

                        <!-- CONTEXT TYPE -->
                        <div style="
                            background: #f8f9fa;
                            border-radius: 12px;
                            padding: 14px 20px;
                            margin-bottom: 16px;
                            border: 1px solid #e9ecef;
                        ">
                            <div style="font-size: 12px; color: #6c757d; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;">
                                CHU DE TIM KIEM
                            </div>
                            <field name="loai_context" widget="radio" options="{'horizontal': true}" nolabel="1"/>
                        </div>

                        <!-- QUESTION BOX -->
                        <div style="position: relative; margin-bottom: 16px;">
                            <div style="
                                background: #ffffff;
                                border: 2px solid #e3e8f0;
                                border-radius: 14px;
                                padding: 4px;
                                transition: border-color 0.2s;
                                box-shadow: 0 2px 8px rgba(0,0,0,0.06);
                            ">
                                <field name="cau_hoi"
                                       nolabel="1"
                                       placeholder="Vi du: Ai di muon nhieu nhat thang nay? Tong quy luong la bao nhieu?..."
                                       style="
                                           border: none;
                                           box-shadow: none;
                                           font-size: 14px;
                                           padding: 12px 16px;
                                           min-height: 80px;
                                           resize: vertical;
                                       "/>
                            </div>
                        </div>

                        <!-- ANSWER BOX -->
                        <div attrs="{'invisible': [('tra_loi', '=', False)]}" style="
                            background: linear-gradient(135deg, #1565c0 0%, #0d47a1 100%);
                            border-radius: 14px;
                            padding: 20px 24px;
                            margin-bottom: 16px;
                            box-shadow: 0 4px 20px rgba(21,101,192,0.3);
                        ">
                            <div style="display: flex; align-items: center; margin-bottom: 12px; gap: 8px;">
                                <div style="
                                    width: 28px; height: 28px;
                                    background: rgba(255,255,255,0.2);
                                    border-radius: 50%;
                                    display: flex; align-items: center; justify-content: center;
                                ">
                                    <i class="fa fa-comment" style="font-size: 13px; color: white;"/>
                                </div>
                                <span style="color: rgba(255,255,255,0.9); font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                                    Trả lời từ AI
                                </span>
                            </div>
                            <div style="
                                background: rgba(255,255,255,0.1);
                                border-radius: 10px;
                                padding: 14px 16px;
                            ">
                                <field name="tra_loi" nolabel="1" style="
                                    color: #ffffff !important;
                                    font-size: 14px;
                                    line-height: 1.7;
                                    border: none !important;
                                    background: transparent !important;
                                    box-shadow: none !important;
                                "/>
                            </div>
                        </div>

                        <!-- SUGGESTION CHIPS -->
                        <div style="
                            background: #fff8e1;
                            border-radius: 12px;
                            padding: 14px 18px;
                            border-left: 4px solid #ffc107;
                        ">
                            <div style="font-size: 12px; font-weight: 700; color: #856404; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px;">
                                Goi y cau hoi
                            </div>
                            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                                <span style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 20px; padding: 4px 12px; font-size: 12px; color: #664d03;">Có bao nhiêu nhân viên đang làm việc?</span>
                                <span style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 20px; padding: 4px 12px; font-size: 12px; color: #664d03;">Ai đi muộn nhiều nhất tháng này?</span>
                                <span style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 20px; padding: 4px 12px; font-size: 12px; color: #664d03;">Tổng quỹ lương tháng này?</span>
                                <span style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 20px; padding: 4px 12px; font-size: 12px; color: #664d03;">Phòng ban nào đông nhân viên nhất?</span>
                                <span style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 20px; padding: 4px 12px; font-size: 12px; color: #664d03;">Thống kê nhân viên theo giới tính?</span>
                            </div>
                        </div>
                    </sheet>

                    <footer>
                        <button name="action_hoi_ai"
                                string="  Gửi câu hỏi"
                                type="object"
                                class="btn-primary"
                                icon="fa-paper-plane"
                                style="
                                    background: linear-gradient(135deg, #1976d2, #1565c0) !important;
                                    border: none !important;
                                    border-radius: 8px !important;
                                    padding: 8px 24px !important;
                                    font-weight: 600 !important;
                                    box-shadow: 0 4px 12px rgba(25,118,210,0.4) !important;
                                "/>
                        <button string="Đóng" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        
        <!-- Action - Mở AI Assistant -->
        <record id="action_ai_assistant" model="ir.actions.act_window">
            <field name="name">Hỏi AI Assistant</field>
            <field name="res_model">ai.assistant</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        
    </data>
</odoo>
