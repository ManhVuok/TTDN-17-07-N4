<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduled Action to generate monthly payroll -->
        <record id="ir_cron_generate_monthly_payroll" model="ir.cron">
            <field name="name">Tính Lương: Tự động tạo bảng lương hàng tháng</field>
            <field name="model_id" ref="model_bang_luong"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_monthly_payroll()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(datetime.now().replace(day=1, hour=1, minute=0, second=0) + relativedelta(months=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
